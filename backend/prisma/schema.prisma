generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Integration {
  id        Int      @id @default(autoincrement())
  name      String
  status    String
  createdAt  DateTime @default(now())
}

model Workflow {
  id        Int      @id @default(autoincrement())
  name      String
  status    String
  createdAt  DateTime @default(now())
}

model LogEntry {
  id        Int      @id @default(autoincrement())
  message   String
  timestamp String
  createdAt DateTime @default(now())
}
